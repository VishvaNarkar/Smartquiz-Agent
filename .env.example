# Environment variables for SmartQuiz Agent
# Copy this to .env and fill in your values

# Ollama Configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1:8b

# Cloud model key (recommended over UI persistence)
SMARTQUIZ_CLOUD_API_KEY=

# Auth token signing secret (required for shared/public deployments)
SMARTQUIZ_AUTH_SECRET=

# Note: Place your Google credentials.json in auth/ directory
# No need to set it here as it's loaded from file